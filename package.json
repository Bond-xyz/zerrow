{
  "name": "zerrow-protocol",
  "version": "1.0.0",
  "description": "Zerrow Lending Protocol",
  "scripts": {
    "build": "forge build",
    "compile": "npm run build",
    "test": "npm run test:protocol && npm run test:upgrade && npm run test:ops",
    "test:protocol": "forge test --offline --match-contract AuditFixVerification",
    "test:upgrade": "forge test --offline --match-path test/UpgradeabilityTest.t.sol",
    "test:ops": "forge test --offline --match-path test/OpsAndDeploymentParityTest.t.sol",
    "test:fork": "forge test --offline --match-contract RedstoneOracleForkTest --fork-url $ZERO_G_RPC_URL",
    "deploy:protocol": "./scripts/deploy-protocol.sh",
    "configure:markets": "./scripts/configure-markets.sh",
    "handoff:admin": "./scripts/handoff-admin.sh"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.2.0",
    "@openzeppelin/contracts-upgradeable": "4.2.0"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@openzeppelin/hardhat-upgrades": "^1.28.0",
    "chai": "^4.3.10",
    "ethereum-waffle": "^3.4.4",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.2"
  }
}
